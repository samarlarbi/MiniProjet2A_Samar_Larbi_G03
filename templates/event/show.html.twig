{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;">
        <div class="glass card">
            {% if event.image %}
                <img src="{{ event.image }}" alt="{{ event.title }}" class="card-img" style="height: 300px;">
            {% else %}
                 <div class="card-img" style="height: 300px; background: linear-gradient(135deg, var(--surface-color), var(--bg-color)); display: flex; align-items: center; justify-content: center; color: var(--text-muted); border-bottom: 1px solid var(--border-color);">
                    Image non disponible
                </div>
            {% endif %}
            
            <div class="card-body">
                <h1 style="margin-top: 0;">{{ event.title }}</h1>
                <p><strong>Date & Heure:</strong> <span style="color: var(--accent-1);">{{ event.date ? event.date|date('d/m/Y H:i') : '' }}</span></p>
                <p><strong>Lieu:</strong> {{ event.location }}</p>
                <p><strong>Disponibilité:</strong> 
                    {% set available = event.seats - event.reservations|length %}
                    {% if available > 0 %}
                        <span style="color: var(--success); font-weight: bold;">{{ available }} places restantes</span>
                    {% else %}
                        <span style="color: var(--danger); font-weight: bold;">Complet</span>
                    {% endif %}
                </p>
                <hr style="border-color: var(--border-color); margin: 2rem 0;">
                <div>
                    <h3 style="margin-bottom: 1rem; color: var(--text-muted);">Description</h3>
                    <p style="line-height: 1.6;">{{ event.description|nl2br }}</p>
                </div>
            </div>
        </div>

        <div class="glass card" id="reservation-section" style="display: none;">
            <div class="card-body">
                <h2 style="margin-top: 0;">Réserver votre place</h2>
                
                {% set available = event.seats - event.reservations|length %}
                {% if available > 0 %}
                    {{ form_start(form) }}
                        <div class="form-group">
                            {{ form_label(form.name) }}
                            {{ form_widget(form.name) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.phone) }}
                            {{ form_widget(form.phone) }}
                        </div>

                        <button type="submit" class="btn" style="width: 100%;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 8px;">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                            Confirmer la Réservation
                        </button>
                    {{ form_end(form) }}
                {% else %}
                    <div class="alert alert-error">Les réservations sont closes pour cet événement.</div>
                {% endif %}
            </div>
        </div>

        <div class="glass card" id="login-required-section" style="display: block;">
            <div class="card-body text-center" style="text-align: center; padding: 3rem 1rem;">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted); margin-bottom: 1rem;">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
                <h2 style="margin-top: 0;">Authentification Requise</h2>
                <p style="color: var(--text-muted); margin-bottom: 2rem;">Vous devez être connecté pour réserver une place pour cet événement.</p>
                <a href="{{ path('app_login') }}" class="btn">Me Connecter</a>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const token = localStorage.getItem('jwt_token');
        if (token) {
            document.getElementById('reservation-section').style.display = 'block';
            document.getElementById('login-required-section').style.display = 'none';

            try {
                const payload = JSON.parse(atob(token.split('.')[1]));
                const emailInput = document.getElementById('reservation_email');
                if (emailInput && !emailInput.value && payload.username) {
                    emailInput.value = payload.username;
                }
            } catch(e) {}
        }
    });
</script>
{% endblock %}
