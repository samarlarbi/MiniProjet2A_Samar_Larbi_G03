<form method="post" action="{{ path('app_admin_event_delete', {'id': event.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet événement ?');" style="display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
    <button class="btn btn-outline" style="padding: 0.4rem 0.8rem; font-size: 0.85em; border-color: var(--danger); color: var(--danger);">Supprimer</button>
</form>
